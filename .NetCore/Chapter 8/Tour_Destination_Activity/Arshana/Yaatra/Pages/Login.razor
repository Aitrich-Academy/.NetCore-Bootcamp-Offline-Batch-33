@page "/login"

<div class="login-container">

    <div class="login-card">

        <h3>Welcome Back</h3>
        <p class="subtitle">Please log in to your account</p>

        <div class="form-group">
            <label>Username</label>
            <input type="text"
                   class="form-control"
                   placeholder="Enter your username"
                   @bind="username" />
        </div>

        <div class="form-group">
            <label>Password</label>

            <div class="password-box">

                <input type="@passwordType"
                       class="form-control"
                       placeholder="Enter your password"
                       @bind="password" />

                <i class="@eyeIcon"
                   @onclick="TogglePassword"></i>

            </div>
        </div>

        <div class="options">

            <label>
                <input type="checkbox" /> Remember me
            </label>

            <a href="#">Forgot Password?</a>

        </div>

        <button class="login-btn" @onclick="LoginUser">
            Login
        </button>

        <p class="signup">
            Don't have an account?
            <a href="/signup">Sign Up</a>
        </p>

    </div>

</div>
<style>
    .login-container {
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(90deg,#6a8cff,#a06bff);
    }

    .login-card {
        width: 350px;
        background: white;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0px 6px 25px rgba(0,0,0,0.2);
    }

        .login-card h3 {
            text-align: center;
        }

    .subtitle {
        text-align: center;
        font-size: 14px;
        color: gray;
        margin-bottom: 20px;
    }

    .form-group {
        margin-bottom: 15px;
    }

    .form-control {
        width: 100%;
        padding: 10px;
        border-radius: 6px;
        border: 1px solid #ccc;
    }

    .password-box {
        position: relative;
    }

        .password-box input {
            padding-right: 40px;
        }

        .password-box i {
            position: absolute;
            right: 12px;
            top: 10px;
            cursor: pointer;
            font-size: 18px;
            color: gray;
        }

    .options {
        display: flex;
        justify-content: space-between;
        margin-top: 10px;
        margin-bottom: 20px;
        font-size: 14px;
    }

    .login-btn {
        width: 100%;
        padding: 10px;
        border: none;
        border-radius: 6px;
        background: #e5e5e5;
        font-weight: bold;
        margin-bottom: 15px;
    }

    .signup {
        text-align: center;
        font-size: 14px;
    }
</style>


@code {

    string? username;
    string? password;

    string passwordType = "password";
    string eyeIcon = "bi bi-eye";

    void TogglePassword()
    {
        if (passwordType == "password")
        {
            passwordType = "text";
            eyeIcon = "bi bi-eye-slash";
        }
        else
        {
            passwordType = "password";
            eyeIcon = "bi bi-eye";
        }
    }

    void LoginUser()
    {
        Console.WriteLine($"Username: {username}");
    }

}