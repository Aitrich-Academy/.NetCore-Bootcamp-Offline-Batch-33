@page "/edit-consultant/{id:int}"

@using Yaatra.Dto
@using Yaatra.Services

@inject ConsultantService service
@inject NavigationManager Navigation

<h3>Edit Consultant</h3>

<div class="card p-4">

    <div class="mb-3">
        <label>Name</label>
        <input class="form-control" @bind="consultant.Name" />
    </div>

    <div class="mb-3">
        <label>Email</label>
        <input class="form-control" @bind="consultant.Email" />
    </div>

    <div class="mb-3">
        <label>Phone</label>
        <input class="form-control" @bind="consultant.Phone" />
    </div>

    <div class="mb-3">
        <label>Username</label>
        <input class="form-control" @bind="consultant.Username" />
    </div>

    <InputDate class="form-control" @bind-Value="consultant.JoiningDate" />

    <button class="btn btn-primary" @onclick="UpdateConsultant">
        Update
    </button>

    <button class="btn btn-secondary ms-2" @onclick="GoBack">
        Cancel
    </button>

</div>

@code {

    [Parameter]
    public int id { get; set; }

    ConsultantDto consultant = new();

    protected override async Task OnInitializedAsync()
    {
        consultant = await service.GetById(id);
    }

    async Task UpdateConsultant()
    {
        await service.Update(consultant);

        Navigation.NavigateTo("/consultants");
    }

    void GoBack()
    {
        Navigation.NavigateTo("/consultants");
    }

}