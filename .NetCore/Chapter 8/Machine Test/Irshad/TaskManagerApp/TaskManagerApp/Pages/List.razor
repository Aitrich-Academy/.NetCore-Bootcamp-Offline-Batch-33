@page "/list"
@using TaskManagerApp.Model
@using TaskManagerApp.Service
@using TaskManagerApp.Interface
@inject ITaskService TaskService
@inject NavigationManager NavigationManager

<h3>List</h3>
<button class="btn btn-primary" @onclick="GoToAdd">Add Task</button>

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Title</th>
            <th>Description</th>
            <th>Due Date</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var task in tasks)
        {
            <tr>
                <td>@task.Id</td>
                <td>@task.Title</td>
                <td>@task.Description</td>
                <td>@task.DueDate.ToShortDateString()</td>
                <td>@(task.IsCompleted ? "Yes" : "No")</td>
                <td>
                    <button class="btn btn-danger" @onclick="() => DeleteTask(task.Id)">Delete</button>
                    @if (!task.IsCompleted)
                    {
                        <button class="btn btn-success" @onclick="() => MarkComplete(task.Id)">Mark Complete</button>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<TaskList> tasks = new List<TaskList>();

    protected override async Task OnInitializedAsync()
    {
        tasks = await TaskService.GetAllTasksAsync();
    }

    private async Task DeleteTask(int id)
    {
        await TaskService.DeleteTaskAsync(id);
        tasks = await TaskService.GetAllTasksAsync();
    }

    private async Task MarkComplete(int id)
    {
        await TaskService.MarkComplete(id);
        tasks = await TaskService.GetAllTasksAsync();
    }
    private void GoToAdd()
    {
        NavigationManager.NavigateTo("./create");
    }
}
