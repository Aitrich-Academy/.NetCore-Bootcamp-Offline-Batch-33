@page "/login"

@using TourManageDb.Interface
@inject IUserService UserService
@inject NavigationManager Nav
@inject Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage.ProtectedSessionStorage ProtectedSessionStore

<h3>Login</h3>
<hr />

<div class="row">
    <div class="col-md-4">

        <EditForm Model="login" OnValidSubmit="HandleLogin">

            <DataAnnotationsValidator />
            <ValidationSummary />

            <!-- Email -->
            <div class="form-group">
                <label>Email</label>

                <InputText class="form-control"
                           @bind-Value="login.Email" />

                <ValidationMessage For="@(() => login.Email)" />
            </div>

            <!-- Password -->
            <div class="form-group">
                <label>Password</label>

                <InputText type="password"
                           class="form-control"
                           @bind-Value="login.Password" />

                <ValidationMessage For="@(() => login.Password)" />
            </div>

            <p>
                Don't have an account? <a href="/register">Register</a>
            </p>

            <button type="submit" class="btn btn-primary mt-2" disabled="@isSubmitting">
                Login
            </button>

        </EditForm>

    </div>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="text-danger mt-2">
        @errorMessage
    </div>
}

@code {

    private LoginModel login = new();
    private string? errorMessage;
    private bool isSubmitting;

    private async Task HandleLogin()
    {
        isSubmitting = true;

        var user = await UserService.LoginAsync(login.Email!, login.Password!);

        Console.WriteLine(user == null ? "Login failed" : "Login success");

        if (user != null)
        {
            // store user info in ProtectedSessionStorage so layout and other pages can read it
            await ProtectedSessionStore.SetAsync("UserId", user.Id);
            await ProtectedSessionStore.SetAsync("UserName", user.UserName ?? string.Empty);
            await ProtectedSessionStore.SetAsync("UserRole", user.Role.ToString());

            // Redirect to the TourManage index page (root route)
            Nav.NavigateTo("/", true); // force full reload to let layout re-read storage
        }
        else
        {
            errorMessage = "Invalid email or password";
            isSubmitting = false;
        }
    }

    public class LoginModel
    {
        public string? Email { get; set; }
        public string? Password { get; set; }
    }
}