@page "/consultants"

@using Yaatra.Dto
@using Yaatra.Services

@inject ConsultantService service
@inject NavigationManager Navigation

<h3>Consultant Management</h3>

<button class="btn btn-primary mb-3" @onclick="GoToAdd">
    + Add Consultant
</button>

<table class="table table-bordered table-striped">

    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Username</th>
            <th>Joining Date</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

        @if (consultants.Count == 0)
        {
            <tr>
                <td colspan="6">No Consultants Found</td>
            </tr>
        }

        @foreach (var c in consultants)
        {
            <tr>
                <td>@c.Name</td>
                <td>@c.Email</td>
                <td>@c.Phone</td>
                <td>@c.Username</td>
                <td>@c.JoiningDate?.ToString("dd-MM-yyyy")</td>
                
                

                <td>

                    @* <img src="icons/eye.png"
                         width="22"
                         style="cursor:pointer; margin-right:10px"
                         @onclick="() => ViewConsultant(c.Id)" /> *@

                    <img src="icons/pencil.png"
                         width="22"
                         style="cursor:pointer; margin-right:10px"
                         @onclick="() => EditConsultant(c.Id)" />


                    <img src="icons/add.png"
                         width="30"
                         style="cursor:pointer"
                         @onclick="GoToAdd" />
                         

                    <img src="icons/delete.png"
                         width="22"
                         style="cursor:pointer"
                         @onclick="() => DeleteConsultant(c.Id)" />

                </td>

            </tr>
        }

    </tbody>

</table>

@code {

    List<ConsultantDto> consultants = new();

    protected override async Task OnInitializedAsync()
    {
        consultants = await service.GetAll();
    }

    void GoToAdd()
    {
        Navigation.NavigateTo("/add-consultant");
    }

    void EditConsultant(int id)
    {
        Navigation.NavigateTo($"/edit-consultant/{id}");
    }

    async Task DeleteConsultant(int id)
    {
        await service.Delete(id);
        consultants = await service.GetAll();
    }

}