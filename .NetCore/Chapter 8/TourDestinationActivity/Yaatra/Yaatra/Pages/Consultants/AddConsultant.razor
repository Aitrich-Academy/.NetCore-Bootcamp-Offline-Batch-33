@page "/add-consultant"

@using Yaatra.Dto
@using Yaatra.Services

@inject ConsultantService service
@inject NavigationManager Navigation

<h3>Add Consultant</h3>

<div class="card p-4">

    <div class="mb-3">
        <label>Name</label>
        <input class="form-control" @bind="consultant.Name" />
    </div>

    <div class="mb-3">
        <label>Email</label>
        <input class="form-control" @bind="consultant.Email" />
    </div>

    <div class="mb-3">
        <label>Phone</label>
        <input class="form-control" @bind="consultant.Phone" />
    </div>

    <div class="mb-3">
        <label>Username</label>
        <input class="form-control" @bind="consultant.Username" />
    </div>

    <div class="mb-3">
        <label class="form-label">Joining Date</label>
        <InputDate class="form-control" @bind-Value="consultant.JoiningDate" />
    </div>

    <div class="d-flex gap-3">
        <button class="btn btn-success" @onclick="SaveConsultant">
            Save
        </button>

        <button class="btn btn-secondary" @onclick="GoBack">
            Cancel
        </button>
    </div>

</div>

@code {

    

    ConsultantDto consultant = new ConsultantDto
    {
        JoiningDate = DateTime.Today
    };

    async Task SaveConsultant()
    {
        await service.Add(consultant);

        Navigation.NavigateTo("/consultants");
    }

    void GoBack()
    {
        Navigation.NavigateTo("/consultants");
    }



}