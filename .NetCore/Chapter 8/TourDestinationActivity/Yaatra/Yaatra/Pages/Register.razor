@page "/register"

@inject NavigationManager Navigation

<div class="login-container">

    <div class="login-card">

        <h3>Create Account</h3>
        <p class="subtitle">Register to start your journey</p>

        <div class="form-group">
            <label>Full Name</label>
            <input type="text"
                   class="form-control"
                   placeholder="Enter your name"
                   @bind="name" />
        </div>

        <div class="form-group">
            <label>Email</label>
            <input type="email"
                   class="form-control"
                   placeholder="Enter your email"
                   @bind="email" />
        </div>

        <div class="form-group">
            <label>Password</label>

            <div class="password-box">
                <input type="@passwordType"
                       class="form-control"
                       placeholder="Enter password"
                       @bind="password" />

                <i class="@eyeIcon"
                   @onclick="TogglePassword"></i>
            </div>
        </div>

        <div class="form-group">
            <label>Confirm Password</label>
            <input type="password"
                   class="form-control"
                   placeholder="Confirm password"
                   @bind="confirmPassword" />
        </div>

        <button class="login-btn" @onclick="RegisterUser">
            Register
        </button>

        <p class="signup">
            Already have an account?
            <a href="/login">Login</a>
        </p>

    </div>

</div>

<style>
    .login-container {
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(90deg,#6a8cff,#a06bff);
    }

    .login-card {
        width: 350px;
        background: white;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0px 6px 25px rgba(0,0,0,0.2);
    }

    .form-group {
        margin-bottom: 15px;
    }

    .form-control {
        width: 100%;
        padding: 10px;
        border-radius: 6px;
        border: 1px solid #ccc;
    }

    .password-box {
        position: relative;
    }

        .password-box input {
            padding-right: 40px;
        }

        .password-box i {
            position: absolute;
            right: 12px;
            top: 10px;
            cursor: pointer;
        }

    .login-btn {
        width: 100%;
        padding: 10px;
        border: none;
        border-radius: 6px;
        margin-top: 10px;
        background-color: #6a8cff;
        color: white;
    }

    .signup {
        text-align: center;
        margin-top: 10px;
    }
</style>

@code {

    string name;
    string email;
    string password;
    string confirmPassword;

    string passwordType = "password";
    string eyeIcon = "bi bi-eye";

    void TogglePassword()
    {
        if (passwordType == "password")
        {
            passwordType = "text";
            eyeIcon = "bi bi-eye-slash";
        }
        else
        {
            passwordType = "password";
            eyeIcon = "bi bi-eye";
        }
    }

    void RegisterUser()
    {
        if (password != confirmPassword)
        {
            Console.WriteLine("Passwords do not match");
            return;
        }

        // Save user data (demo purpose)
        Console.WriteLine($"Name: {name}");
        Console.WriteLine($"Email: {email}");

        // Navigate to Consultant List Page
        Navigation.NavigateTo("/consultants");
    }

}