@page "/list"
@using JobProvider.Model
@using JobProvider.Interface
@inject NavigationManager Nav
@inject IJobService JobService
@inject IJSRuntime JS

<h3 class="mb-4 text-center">All Jobs</h3>

@if (jobs == null)
{
    <p>Loading...</p>
}
else if (!jobs.Any())
{
    <div class="alert alert-info">No jobs available.</div>
}
else
{
    <div class="container">
        @foreach (var job in jobs)
        {
            <div class="card mb-3 shadow-sm">
                <div class="card-body d-flex justify-content-between align-items-center">

                    <div>
                        <h5 class="fw-bold text-primary">@job.JobTitle</h5>
                        <p class="mb-1 text-muted">@job.JobDescription</p>

                        <span class="badge bg-success me-2">@job.TypeOfWork</span>
                        <span class="badge bg-warning text-dark me-2">@job.Salary</span>
                        <span class="badge bg-secondary">@job.Location</span>
                    </div>

                    <div>
                        <button class="btn btn-danger btn-sm"
                                @onclick="() => ConfirmDelete(job.Id)">
                            Remove
                        </button>

                        <button class="btn btn-primary btn-sm ms-2"
                                @onclick="() => EditJob(job.Id)">
                            Edit
                        </button>
                    </div>

                </div>
            </div>
        }
    </div>
}

@code {

    private List<Job> jobs = new();

    protected override async Task OnInitializedAsync()
    {
        jobs = await JobService.GetJobsAsync();
    }

    private async Task DeleteJob(int id)
    {
        await JobService.DeleteJobAsync(id);
        jobs = await JobService.GetJobsAsync();
    }

    private void EditJob(int id)
    {
        Nav.NavigateTo($"/edit/{id}");
    }

    private async Task ConfirmDelete(int id)
    {
        var confirm = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this job?");
        if (confirm)
        {
            await JobService.DeleteJobAsync(id);
            jobs = await JobService.GetJobsAsync();
        }
    }
}