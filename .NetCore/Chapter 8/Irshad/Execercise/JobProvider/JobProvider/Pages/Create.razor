@page "/create"
@using JobProvider.Model
@using JobProvider.Service
@using JobProvider.Interface
@inject IJobService JobService
@inject NavigationManager Nav

<h3 class="mb-4 text-center">Post Job</h3>

<div class="container" style="max-width:800px;">
    <div class="card shadow p-4">

        <EditForm Model="@job" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">Job Title</label>
                <InputText class="form-control" @bind-Value="job.JobTitle" placeholder="Enter Job Title" />
            </div>

            <div class="mb-3">
                <label class="form-label">Description</label>
                <InputTextArea class="form-control" @bind-Value="job.JobDescription" placeholder="Enter Description" />
            </div>

            <div class="mb-3">
                <label class="form-label">Salary</label>
                <InputNumber class="form-control" @bind-Value="job.Salary" placeholder="Enter Salary" />
            </div>

            <div class="mb-3">
                <label class="form-label">Experience</label>
                <InputText class="form-control" @bind-Value="job.JobExperience" placeholder="Enter Experience" />
            </div>

            <div class="mb-3">
                <label class="form-label">Type Of Work</label>
                <InputText class="form-control" @bind-Value="job.TypeOfWork" placeholder="Full-time / Part-time" />
            </div>

            <div class="mb-3">
                <label class="form-label">Location</label>
                <InputText class="form-control" @bind-Value="job.Location" placeholder="Enter Location" />
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                    Post Job
                </button>

                <button type="button" class="btn btn-secondary ms-2"
                        @onclick="AddJobAsync">
                    Cancel
                </button>
            </div>

        </EditForm>

    </div>
</div>

@code {

    private Job job = new Job();

    private async Task HandleValidSubmit()
    {
        await JobService.AddJobAsync(job);
        Nav.NavigateTo("/list");
    }
    private async Task AddJobAsync()
    {
        await JobService.AddJobAsync(job);
        Nav.NavigateTo("/list");
    }
}