@page
@model TravelsDb.Pages.Tours.EditModel
@{
    ViewData["Title"] = "Edit Tour";
}

<div class="container mt-4">

    <h4 class="fw-bold mb-4">Edit Tour</h4>

    <form method="post">

        <input type="hidden" asp-for="Tour.Id" />

        <div class="mb-3">
            <label>Title</label>
            <input asp-for="Tour.Title" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Description</label>
            <textarea asp-for="Tour.Description"
                      class="form-control"
                      rows="4"></textarea>
        </div>

        <div class="mb-3">
            <label>Destination</label>
            <select asp-for="Tour.DestinationId"
                    class="form-control">
                @foreach (var d in Model.Destinations)
                {
                    <option value="@d.Id">@d.Name</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label>Price</label>
            <input asp-for="Tour.Price"
                   type="number"
                   step="0.01"
                   class="form-control" />
        </div>

        <button class="btn btn-primary">
            Update
        </button>

        <a asp-page="Index"
           class="btn btn-secondary">
            Cancel
        </a>

    </form>
</div>