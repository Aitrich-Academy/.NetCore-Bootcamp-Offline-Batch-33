@page
@model TravelsDb.Pages.Tours.CreateModel
@{
    ViewData["Title"] = "Create Tour";
}

<div class="container mt-4">

    <h4 class="fw-bold mb-4">Create Tour</h4>

    <form method="post">

        <!-- Title -->
        <div class="mb-3">
            <label class="form-label">Title</label>
            <input asp-for="Tour.Title" class="form-control" />
            <span asp-validation-for="Tour.Title" class="text-danger"></span>
        </div>

        <!-- Description -->
        <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea asp-for="Tour.Description"
                      class="form-control"
                      rows="4"></textarea>
            <span asp-validation-for="Tour.Description" class="text-danger"></span>
        </div>

        <!-- Destination Dropdown -->
        <div class="mb-3">
            <label class="form-label">Destination</label>
            <select asp-for="Tour.DestinationId"
                    class="form-control">
                <option value="">Select Destination</option>
                @foreach (var d in Model.Destinations)
                {
                    <option value="@d.Id">@d.Name</option>
                }
            </select>
            <span asp-validation-for="Tour.DestinationId" class="text-danger"></span>
        </div>

        <!-- Price -->
        <div class="mb-3">
            <label class="form-label">Price</label>
            <input asp-for="Tour.Price"
                   type="number"
                   step="0.01"
                   class="form-control" />
            <span asp-validation-for="Tour.Price" class="text-danger"></span>
        </div>

        <button type="submit"
                class="btn btn-primary">
            Save
        </button>

        <a asp-page="Index"
           class="btn btn-secondary">
            Cancel
        </a>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}